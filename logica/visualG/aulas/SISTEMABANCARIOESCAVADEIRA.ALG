Algoritmo "SistemaBancarioEscavadeira"
// Disciplina   : Linguagem e Lógica de Programaçăo com VisualG
// Professor   : Jailson
// Descriçăo   : Sistema bancário completo
// Autor(a)    : Guilherme Custódio Nieto
// Data atual  : 02/04/2026
Var
   // Seçăo de Declaraçőes das variáveis
   agencia, conta, senha: inteiro

Inicio
   // Seçăo de Comandos, procedimento, funçőes, operadores, etc...
   Escreval("Sistema bancário da escavadeira")
   Escreval("")
   repita
      Escreval("Entre com sua agęncia, sua conta e sua senha")
      Escreval("")



      Escreval("Informe a sua agęncia")
      leia(agencia)
      tempo 55
      limpatela


      Escreval("Sistema bancário da escavadeira")
      Escreval("")

      Escreval("Informe a sua conta")
      leia(conta)
      tempo 55
      limpatela

      Escreval("Sistema bancário da escavadeira")
      Escreval("")
      Escreval("Entre com sua agęncia, sua conta e sua senha")
      Escreval("")
      Escreval("Informe a sua senha")
      leia(senha)
      tempo 55
      limpatela

      se (agencia =    1234) e (conta = 5678) e (senha = 1234) entao
         escreval("Acesso permitido")
         tempo 55
      senao
         escreval("Acesso negado")
         tempo 55
      fimse

      tempo 800
      limpatela


   ate (agencia =    1234) e (conta = 5678) e (senha = 1234)

   tempo 55
   Escreval("Sistema bancário da escavadeira")
   Escreval("")
   Escreval("Selecione uma opçăo para utilizar o sistema bancário")
   Escreval("1 - Saldo")
   Escreval("2 - Transferęncia")
   Escreval("3 - Depósito")
   Escreval("4 - Extrato")
   Escreval("5 - Saque")
   Escreval("6 - Pix")
   Escreval("7 - Empréstimo")
   Escreval("8 - Cartőes")


Fimalgoritmo